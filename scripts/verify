#!/bin/bash
# Single verification entrypoint. AGENTS.md's Definition of Done defers to
# this file, so the gate lives in exactly one place. Runs every component
# gate so one green run covers any change. Live-marked tests stay excluded
# (api/tests/conftest.py skips them unless -m live is passed explicitly).
set -euo pipefail
cd "$(dirname "$0")/.."

# Use the repo venv when present so tests run against the pinned dependencies.
PY=python3
if [[ -x .venv/bin/python ]]; then
  PY=.venv/bin/python
fi

echo "==> api: pytest"
"$PY" -m pytest api/tests/ -q

echo "==> api: parser test runner"
"$PY" api/tests/run_parser_tests.py

echo "==> mcp: typecheck"
(cd mcp && npm run typecheck)

echo "==> mcp: build"
(cd mcp && npm run build)

echo "==> web: test"
(cd web && npm test)

echo "==> web: build"
(cd web && npm run build)

echo "OK: all gates green"
